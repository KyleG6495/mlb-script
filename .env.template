# ═══════════════════════════════════════════════════════════════════════════════
# 🔐 MLB MODEL ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# 
# INSTRUCTIONS:
# 1. Copy this file to '.env' in your project root directory
# 2. Replace the placeholder values with your actual API keys and settings
# 3. Never commit the .env file to version control (add it to .gitignore)
# 
# SECURITY NOTE:
# Keep your API keys secure and never share them publicly
# ═══════════════════════════════════════════════════════════════════════════════

# 🌤️ Weather API Configuration
OPENWEATHER_API_KEY=your_openweather_api_key_here

# 📊 Sports Data APIs (if using premium sources)
SPORTSDATA_API_KEY=your_sportsdata_api_key_here
FANDUEL_API_KEY=your_fanduel_api_key_here

# 🗄️ Database Configuration (if using)
DATABASE_URL=your_database_connection_string_here
REDIS_URL=your_redis_connection_string_here

# 📁 Custom Path Overrides (optional)
CUSTOM_DATA_DIR=C:\Your\Custom\Data\Path
CUSTOM_SLATE_DIR=C:\Your\Custom\Slate\Path

# 🎛️ Model Settings Override
ROLLING_WINDOW_DAYS=5
MIN_GAMES_FOR_ROLLING=3
DEFAULT_LINEUP_COUNT=20

# 🔧 Debug and Testing
DEBUG_MODE=false
ENABLE_DETAILED_LOGGING=true
USE_CACHED_DATA=false

# 💰 DFS Settings
FANDUEL_SALARY_CAP=35000
MAX_EXPOSURE_PCT=40.0
MIN_EXPOSURE_PCT=5.0

# ⚡ Performance Settings
API_TIMEOUT_SECONDS=10
API_DELAY_SECONDS=1
MAX_CONCURRENT_REQUESTS=5
